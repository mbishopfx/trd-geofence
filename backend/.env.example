# API
PORT=3000
CORS_ORIGIN=*
# Runtime role: api | ingest | qualifier | activation | scheduler | all-workers
SERVICE_ROLE=api

# DSP infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trd_geofence
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=trd_dsp
ENABLE_QUEUE_WORKERS=true
EXPORTS_DIR=./exports

# Operator auth (optional; if set, send x-operator-key for push/export/declaration endpoints)
OPERATOR_API_KEY=

# Privacy + hashing
DEVICE_HASH_SALT=replace-with-random-salt
INGEST_SIGNATURE_REQUIRED=true

# Pilot defaults (Wichita Falls)
PILOT_TENANT_ID=tenant_nissan_wichita_falls
PILOT_TENANT_NAME=Nissan Wichita Falls Pilot
PILOT_DEALERSHIP_ID=dealership_nissan_wichita_falls
PILOT_DEALERSHIP_NAME=Nissan of Wichita Falls
PILOT_DEALERSHIP_ADDRESS=4000 Kell West Blvd, Wichita Falls, TX 76309
PILOT_DEALERSHIP_LAT=33.8806084
PILOT_DEALERSHIP_LNG=-98.5460791
PILOT_PARTNER_SOURCE_ID=partner_nissan_feed
PILOT_PARTNER_SOURCE_NAME=Nissan Partner Feed
PILOT_PARTNER_SOURCE_SECRET=replace-me

# Qualification defaults
QUALIFY_MAX_ACCURACY_M=100
QUALIFY_COOLDOWN_HOURS=24
QUALIFY_SESSION_BOUNDARY_MIN=20
QUALIFY_LATE_EVENT_GRACE_MIN=30
QUALIFY_RETARGET_DAYS=21

# Worker tuning
INGEST_WORKER_CONCURRENCY=4
QUALIFIER_WORKER_CONCURRENCY=6
ACTIVATION_WORKER_CONCURRENCY=3
SCHEDULER_WORKER_CONCURRENCY=1
SCHEDULER_EXPIRY_INTERVAL_SEC=3600

# Google Ads integration
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# Alternative OAuth source:
# GOOGLE_OAUTH_CLIENT_SECRETS_FILE=./secrets/google_oauth_client.json
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_NISSAN_CUSTOMER_ID=7891399350
GOOGLE_ADS_NISSAN_ACCOUNT_NAME=Nissan Wichita Falls
GOOGLE_ADS_API_VERSION=v22

# Auto sync
GOOGLE_ADS_AUTO_SYNC_ENABLED=true
GOOGLE_ADS_AUTO_SYNC_INTERVAL_SEC=300
GOOGLE_ADS_AUTO_SYNC_RUN_ON_START=true
